<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarMoving"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#4F46E5"
        app:title="Schedule Moving"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"/>

    <EditText
        android:id="@+id/edtMovingDate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="24dp"
        android:hint="Moving Date (e.g., 07/20/2026)"
        android:inputType="date"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/toolbarMoving"/>

    <EditText
        android:id="@+id/edtMovingTime"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:hint="Preferred Time (e.g., 09:00 AM)"
        android:inputType="time"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/edtMovingDate"/>

    <EditText
        android:id="@+id/edtMovingNotes"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:hint="Notes (e.g., Moving In, Moving Out, Large Truck)"
        android:inputType="textMultiLine"
        android:gravity="top"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/edtMovingTime"/>

    <Button
        android:id="@+id/btnSaveMoving"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="24dp"
        android:text="Schedule Moving Date"
        android:backgroundTint="#4F46E5"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/edtMovingNotes"/>

</androidx.constraintlayout.widget.ConstraintLayout>