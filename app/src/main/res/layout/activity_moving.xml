<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarMoving"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#4F46E5"
        app:title="Schedule Moving"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"/>

    <EditText
        android:id="@+id/edtMovingName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="24dp"
        android:hint="Responsible Name"
        android:inputType="textPersonName"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/toolbarMoving"/>

    <EditText
        android:id="@+id/edtMovingApt"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:hint="Apartment Number"
        android:inputType="number"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/edtMovingName"/>

    <EditText
        android:id="@+id/edtMovingDate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:hint="Date (e.g., 07/20/2026)"
        android:inputType="date"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/edtMovingApt"/>

    <EditText
        android:id="@+id/edtMovingType"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:hint="Type (Move In / Move Out)"
        android:inputType="text"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background_normal"
        app:layout_constraintTop_toBottomOf="@id/edtMovingDate"/>

    <Button
        android:id="@+id/btnSaveMoving"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_margin="24dp"
        android:text="Schedule"
        android:backgroundTint="#4F46E5"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/edtMovingType"/>

</androidx.constraintlayout.widget.ConstraintLayout>